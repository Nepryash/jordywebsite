{
  "name": "electro-business-site",
  "version": "1.0.0",
  "private": true,
  "description": "Full-stack marketing website inspired by a Figma design.",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite",
    "prebuild": "node -e \"const fs=require('fs'); try { fs.chmodSync('node_modules/.bin/vue-tsc', 0o755); } catch (e) {}\"",
    "build": "vue-tsc --noEmit && vite build && tsc -p tsconfig.server.json",
    "start": "node dist-server/index.js"
  },
  "dependencies": {
    "express": "^5.2.1",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "concurrently": "^9.2.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vue-tsc": "^3.2.6"
  }
}
